# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_dev_guild_id_here   # solo para dev, para registrar slash commands

# Database
DATABASE_URL="postgresql://euxora:euxora_dev@localhost:5432/euxora"

# Redis
